# Server
PORT=3001

# Database
DATABASE_URL=postgresql://docsense:docsense123@localhost:5432/docsense

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Internal service-to-service auth (must match apps/web INTERNAL_SECRET)
INTERNAL_SECRET=change-me-in-production

# Email — used for OTP and password reset
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@docsense.app

# Frontend URL — used in email links
APP_URL=http://localhost:3000
