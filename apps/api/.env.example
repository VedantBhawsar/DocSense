# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://docsense:docsense123@localhost:5432/docsense

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-different-from-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

# Internal service-to-service auth (must match between apps/api and apps/web)
INTERNAL_SECRET=change-me-internal-shared-secret

# Email (OTP & password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@docsense.app

# Frontend URL (used in email links)
APP_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=docs
MINIO_USE_SSL=false

# OpenAI / NVIDIA (embeddings - used by worker & api)
OPENAI_API_KEY=your-openai-or-nvidia-api-key
# For chat/llm (optional, falls back to OPENAI_API_KEY)
OPENAI_API_KEY_CHAT=