# ── Database ──────────────────────────────────────────────────────
DB_USER=docsense
DB_PASSWORD=docsense123
DB_NAME=docsense

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-different-from-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Internal service auth (must match between api and web) ────────
INTERNAL_SECRET=change-me-internal-shared-secret

# ── MinIO credentials ─────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=docs

# ── NVIDIA / OpenAI (embeddings + chat) ───────────────────────────
# Get your key at https://integrate.api.nvidia.com
OPENAI_API_KEY=nvapi-your-key-here
OPENAI_API_KEY_CHAT=nvapi-your-chat-key-here

# ── SMTP (email OTP & password reset) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ── Public URLs ───────────────────────────────────────────────────
APP_URL=http://your-vps-ip-or-domain
CORS_ORIGIN=http://your-vps-ip-or-domain
NEXTAUTH_URL=http://your-vps-ip-or-domain
NEXTAUTH_SECRET=change-me-nextauth-secret

# ── Google OAuth (optional — leave blank to disable) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
